{
  "name": "esfera-helper",
  "version": "0.4.0",
  "description": "Agilitza la introduccio de qualificacions a Esfer@ amb exportacio/importacio CSV i Google Sheets per a docents de Catalunya.",
  "private": true,
  "scripts": {
    "lint": "eslint extension/ tests/",
    "lint:fix": "eslint --fix extension/ tests/",
    "format": "prettier --write \"extension/**/*.{js,json,html,css}\" \"tests/**/*.js\"",
    "format:check": "prettier --check \"extension/**/*.{js,json,html,css}\" \"tests/**/*.js\"",
    "test": "node --test tests/unit.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1"
  }
}
